import java.util.*;

class Item {
    int id;
    String name;
    int quantity;
    double price;

    Item(int id, String name, int quantity, double price) {
        this.id = id;
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }

    void display() {
        System.out.println(id + " | " + name + " | Qty: " + quantity + " | ₹" + price);
    }
}

class Inventory {

    private Map<Integer, Item> items = new HashMap<>();
    private final int LOW_STOCK_LIMIT = 5;

    public void addItem(int id, String name, int qty, double price) {
        if (items.containsKey(id)) {
            System.out.println("Item already exists!");
            return;
        }
        items.put(id, new Item(id, name, qty, price));
        System.out.println("Item added!");
    }

    public void updateItem(int id, int qty, double price) {
        if (!items.containsKey(id)) {
            System.out.println("Item not found!");
            return;
        }
        Item item = items.get(id);
        item.quantity = qty;
        item.price = price;
        System.out.println("Item updated!");
    }

    public void removeItem(int id) {
        if (items.remove(id) != null)
            System.out.println("Item removed!");
        else
            System.out.println("Item not found!");
    }

    public void searchItem(String name) {
        boolean found = false;
        for (Item i : items.values()) {
            if (i.name.equalsIgnoreCase(name)) {
                i.display();
                found = true;
            }
        }
        if (!found) System.out.println("Item not found.");
    }

    public void showInventory() {
        if (items.isEmpty()) {
            System.out.println("No items in inventory.");
            return;
        }

        System.out.println("\n--- Inventory ---");
        for (Item i : items.values()) {
            i.display();
        }
    }

    public void lowStockAlert() {
        System.out.println("\n--- Low Stock Items ---");
        boolean found = false;

        for (Item i : items.values()) {
            if (i.quantity <= LOW_STOCK_LIMIT) {
                i.display();
                found = true;
            }
        }

        if (!found) System.out.println("No low stock items.");
    }

    public void totalValue() {
        double total = 0;

        for (Item i : items.values()) {
            total += i.quantity * i.price;
        }

        System.out.println("Total Inventory Value: ₹" + total);
    }
}

public class WarehouseSystem {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        Inventory inv = new Inventory();

        int choice;

        do {
            System.out.println("\n=== 📦 Warehouse Inventory System ===");
            System.out.println("1. Add Item");
            System.out.println("2. Update Item");
            System.out.println("3. Remove Item");
            System.out.println("4. Search Item");
            System.out.println("5. View Inventory");
            System.out.println("6. Low Stock Alert");
            System.out.println("7. Total Inventory Value");
            System.out.println("8. Exit");
            System.out.print("Enter choice: ");

            while (!sc.hasNextInt()) {
                System.out.println("Invalid input!");
                sc.next();
            }

            choice = sc.nextInt();

            switch (choice) {

                case 1:
                    System.out.print("Enter ID: ");
                    int id = sc.nextInt();
                    sc.nextLine();

                    System.out.print("Enter name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter quantity: ");
                    int qty = sc.nextInt();

                    System.out.print("Enter price: ");
                    double price = sc.nextDouble();

                    inv.addItem(id, name, qty, price);
                    break;

                case 2:
                    System.out.print("Enter ID: ");
                    id = sc.nextInt();

                    System.out.print("Enter new quantity: ");
                    qty = sc.nextInt();

                    System.out.print("Enter new price: ");
                    price = sc.nextDouble();

                    inv.updateItem(id, qty, price);
                    break;

                case 3:
                    System.out.print("Enter ID: ");
                    inv.removeItem(sc.nextInt());
                    break;

                case 4:
                    sc.nextLine();
                    System.out.print("Enter name: ");
                    inv.searchItem(sc.nextLine());
                    break;

                case 5:
                    inv.showInventory();
                    break;

                case 6:
                    inv.lowStockAlert();
                    break;

                case 7:
                    inv.totalValue();
                    break;

                case 8:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 8);

        sc.close();
    }
}
